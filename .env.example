# =============================================================================
# TradingLab broker / data-vendor credentials
# =============================================================================
#
# Copy this file to `.env` (which is gitignored) and fill in the values for
# whichever vendor(s) you actually use. Missing vendors are silently skipped
# at startup — you only need to provide creds for what you want to enable.
#
# ALL VALUES ARE SECRETS. Do not commit your `.env`.
#
# Loaded by `tradinglab.data.credentials` on first access.

# -----------------------------------------------------------------------------
# Charles Schwab — Trader / Market Data API
# -----------------------------------------------------------------------------
# Register an app at https://developer.schwab.com/ to obtain key + secret.
# Schwab uses OAuth 2.0 with a 7-day refresh token + 30-min access token.
# After your first manual auth, the refresh token is cached at:
#   %LOCALAPPDATA%\tradinglab\tokens\schwab.json   (Windows)
#   ~/.tradinglab/tokens/schwab.json               (macOS/Linux)
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
# OAuth redirect URI registered with your Schwab app. For local dev the
# Schwab sandbox accepts https://127.0.0.1:8182 — must match exactly.
SCHWAB_REDIRECT_URI=https://127.0.0.1

# -----------------------------------------------------------------------------
# Alpaca — Market Data v2 (paper or live)
# -----------------------------------------------------------------------------
# Get keys at https://app.alpaca.markets/ → API Keys.
# For paper-trading data, base URL stays the same; only the key/secret differ.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Optional: override if you need IEX-only feed instead of SIP.
# Valid: "iex" (free tier) | "sip" (paid).
ALPACA_FEED=iex

# -----------------------------------------------------------------------------
# Polygon.io — Aggregates / Snapshots / WebSocket
# -----------------------------------------------------------------------------
# Single API key; tier dictates rate limits + extended hours availability.
POLYGON_API_KEY=
