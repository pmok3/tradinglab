# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Runtime artifacts (live in %LOCALAPPDATA%\tradinglab usually,
# but ignored here in case anyone runs with cwd=repo-root)
*.pkl
settings.json
watchlists.json
*.log

# Coverage
.coverage
htmlcov/
coverage.xml
# `coverage json -o <file>` exports (incl. ad-hoc names like .cov_pol*.json
# committed once in the v0.1.0 snapshot — see commit cf9bc4d... cleanup).
coverage*.json
.cov*.json

# Build metadata generated by tools/build_exe.ps1 (git commit + build
# date embedded into release artifacts). Regenerated on every build;
# never hand-edited or committed.
src/tradinglab/_build_info.py

# Build venv used by tools/build_exe.ps1.
.venv-build/

# PyInstaller scratch (the spec file IS committed; build/ + dist/ are not).
*.spec.bak

# Secrets — broker / data-vendor credentials.
# Never commit real keys. Use .env.example as the template.
.env
.env.local
.env.*.local
# Plaintext vendor credential files read by data.credentials (user-provided,
# never committed). Case variants covered for Windows filesystems.
[Aa]lpaca.txt
[Cc]redentials.txt

# Token caches written by OAuth-based vendors (Schwab refresh tokens etc.).
# Path convention: ~/.tradinglab/tokens/<vendor>.json — but we also
# guard the in-repo path in case anyone configures TOKEN_DIR=.
.tokens/
*.tokens.json

# Local commit-message scratch files (used by the CLI agent because
# multi-line `git commit -m` strings are PowerShell-hostile).
.commit-msg-*.txt

# GUI-test scratch dirs (screenshot probes + fetched-data caches)
_guitest/
_guitest_probe_cache/
